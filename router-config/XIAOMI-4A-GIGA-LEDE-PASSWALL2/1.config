# --- Target Hardware Settings ---
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-4a-gigabit=y

# --- Binary Compression (Essential for 16MB Flash) ---
# CONFIG_IMAGEOPT=y
# CONFIG_BAIDUPCS_WEB_COMPRESS_UPX=y
# CONFIG_FILEBROWSER_COMPRESS_UPX=y
# CONFIG_GOST_COMPRESS_UPX=y
# CONFIG_NPC_COMPRESS_UPX=y
# CONFIG_NPS_COMPRESS_UPX=y

# --- Network Stack (Disable IPv6 to save ROM space) ---
# CONFIG_BUSYBOX_DEFAULT_FEATURE_IPV6 is not set
# CONFIG_IPV6 is not set
# CONFIG_KERNEL_IPV6 is not set

# --- Libcurl Optimization (Keep only essentials) ---
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_PROXY=y
CONFIG_LIBCURL_COOKIES=y
CONFIG_LIBCURL_FILE=y
CONFIG_LIBCURL_FTP=y

# --- [!] Remove Boost Libraries (Save ~2MB Space) ---
# CONFIG_PACKAGE_boost is not set
# CONFIG_PACKAGE_boost-program_options is not set
# CONFIG_PACKAGE_boost-system is not set
# CONFIG_boost-compile-visibility-hidden is not set
# CONFIG_boost-runtime-shared is not set
# CONFIG_boost-static-and-shared-libs is not set
# CONFIG_boost-variant-release is not set

# --- Base System Tools ---
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y

# --- [!] Proxy & Tunneling (Optimized for VLESS) ---
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_xray-core=y

# [!] Remove redundant proxy binaries to save space
# CONFIG_PACKAGE_shadowsocks-libev-ss-local is not set
# CONFIG_PACKAGE_shadowsocks-libev-ss-redir is not set
# CONFIG_PACKAGE_simple-obfs is not set
# CONFIG_PACKAGE_trojan-plus is not set
# CONFIG_PACKAGE_chinadns-ng is not set

# --- Crypto & Kernel Modules ---
CONFIG_PACKAGE_kmod-crypto-kpp=y
CONFIG_PACKAGE_kmod-crypto-lib-blake2s=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y
CONFIG_PACKAGE_libmbedtls=y
# CONFIG_PACKAGE_libstdcpp is not set

# --- WireGuard (Remove if firmware size still > 16MB) ---
CONFIG_PACKAGE_kmod-udptunnel4=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y

# --- Web Interface & Themes ---
CONFIG_PACKAGE_luci-compat=y
# Using Bootstrap theme for minimum storage footprint
CONFIG_PACKAGE_luci-theme-bootstrap=y
# CONFIG_PACKAGE_luci-theme-netgear is not set

# --- Versioning & Distribution Information ---
CONFIG_VERSIONOPT=y
CONFIG_VERSION_DIST="ShisuiWrt"
CONFIG_VERSION_NUMBER="v1-Lite"
CONFIG_VERSION_FILENAMES=y
CONFIG_VERSION_REPO="https://downloads.openwrt.org/snapshots"
